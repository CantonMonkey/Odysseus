# AutoDL 4090 environment config
# Usage: cp .env.autodl .env  (on autodl4090)

# Scene data
VLN_DATA_DIR=/root/autodl-tmp/data/hm3d

# InternVL3-8B local model (after download_model.py)
VLN_LOCAL_MODEL=/root/autodl-tmp/models/OpenGVLab/InternVL3-8B

# vLLM server (comment out VLN_LOCAL_MODEL and use this instead)
# VLN_VLLM_BASE=http://127.0.0.1:8088/v1
# VLN_VLLM_MODEL=InternVL3-8B
